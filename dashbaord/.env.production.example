NODE_ENV=production
PORT=4000
MONGODB_URI=mongodb://your-production-mongodb-host/movexa
JWT_SECRET=replace-with-a-long-random-production-secret
JWT_EXPIRES_IN=7d
ADMIN_SEED_NAME=System Admin
ADMIN_SEED_EMAIL=admin@your-movexa-domain.com
ADMIN_SEED_PASSWORD=replace-with-a-strong-password
FRONTEND_ORIGIN=https://app.your-movexa-domain.com
ADMIN_FRONTEND_ORIGIN=https://staff.your-movexa-domain.com
MAX_IMPORT_FILE_SIZE_MB=25
READ_ONLY_DATABASE=true
