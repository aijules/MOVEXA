NODE_ENV=development
PORT=5000

# Supabase — get from your Supabase project Settings > API
SUPABASE_URL=https://your-project-id.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here
SUPABASE_ANON_KEY=your-anon-key-here

# JWT
JWT_SECRET=movexa-change-this-in-production
JWT_EXPIRES_IN=7d

# Africa's Talking Sandbox
AFRICASTALKING_USERNAME=sandbox
AFRICASTALKING_API_KEY=your-sandbox-api-key
AFRICASTALKING_USSD_SERVICE_CODE=*384*your-code#

# Frontend origin (CORS)
CLIENT_URL=http://localhost:5173
CLIENT_URLS=http://localhost:5173,http://localhost:5174,http://localhost:6001,http://localhost:6002

# UrubutoPay — real MoMo / mobile-money payments
URUBUTO_BASE_URL=https://staging.urubutopay.rw/api
URUBUTO_API_KEY=upg:test_sk_xxx:yyy
URUBUTO_MERCHANT_CODE=your-merchant-code
URUBUTO_SERVICE_CODE=your-service-code
URUBUTO_PAYMENT_CHANNEL=MOMO
# URUBUTO_CALLBACK_URL=https://your-domain/api/payments/webhook
PAYMENT_PENDING_EXPIRY_MINUTES=15
PAYMENT_POLL_ENABLED=true
PAYMENT_POLL_SECONDS=15

# Legacy MongoDB (kept as reference only)
MONGODB_URI=mongodb://localhost:27017/movexa
