{
  "name": "movexa-backend",
  "version": "1.0.0",
  "description": "MoveXa public transport API server",
  "main": "src/server.js",
  "scripts": {
    "dev": "nodemon src/server.js",
    "start": "node src/server.js",
    "build": "node --check src/server.js && node --check src/app.js",
    "seed:routes-stops": "node scripts/ingest/importRoutesWithStops.js",
    "seed:route-paths": "node scripts/ingest/importRoutePaths.js",
    "seed:ecofleet": "node scripts/ingest/importEcofleet.js",
    "generate:schedules": "node scripts/ingest/generateSchedules.js",
    "validate:data": "node scripts/ingest/validateImport.js",
    "seed:all": "node scripts/ingest/seedAll.js",
    "supabase:import-routes": "node scripts/import-routes.js",
    "supabase:import-paths": "node scripts/import-route-paths.js",
    "supabase:seed-buses": "node scripts/seed-buses.js",
    "supabase:seed-drivers": "node scripts/seed-drivers.js",
    "supabase:seed-schedules": "node scripts/seed-schedules.js",
    "supabase:seed-trips": "node scripts/seed-trips.js",
    "supabase:seed-vehicles": "node scripts/seed-live-vehicles.js",
    "supabase:seed-alerts": "node scripts/seed-demo-alerts.js",
    "supabase:seed-all": "node scripts/seed-all.js",
    "data:health": "node scripts/data-health-check.js",
    "payments:check": "node scripts/check-payment-setup.js",
    "test:connection": "node scripts/test-connection.js",
    "seed:demo-corridors": "node scripts/seed-demo-corridors.js",
    "fix:mock-trips": "node scripts/fix-mock-trips-today.js",
    "seed:real-ops": "node scripts/seed-real-operational-mock-data.js",
    "_seed:mock-transport_DISABLED": "echo DISABLED — see scripts/seed-complete-mock-transport-data.js"
  },
  "dependencies": {
    "@supabase/supabase-js": "^2.107.0",
    "bcryptjs": "^2.4.3",
    "chalk": "^4.1.2",
    "cors": "^2.8.5",
    "dayjs": "^1.11.10",
    "dotenv": "^16.4.5",
    "express": "^4.18.3",
    "express-rate-limit": "^7.2.0",
    "helmet": "^7.1.0",
    "joi": "^17.12.3",
    "jsonwebtoken": "^9.0.2",
    "mongoose": "^8.3.1",
    "morgan": "^1.10.0",
    "slugify": "^1.6.6",
    "socket.io": "^4.7.5",
    "uuid": "^14.0.0",
    "xlsx": "^0.18.5"
  },
  "devDependencies": {
    "nodemon": "^3.1.0"
  }
}
